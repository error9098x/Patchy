# ============================================================================
# Patchy Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# GitHub App Configuration
# Register at: https://github.com/settings/apps/new
# ----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-key.pem

# ----------------------------------------------------------------------------
# Cerebras API
# Get API key from: https://cloud.cerebras.ai
# ----------------------------------------------------------------------------
CEREBRAS_API_KEY=

# ----------------------------------------------------------------------------
# Flask Configuration
# Generate SECRET_KEY with: python3 -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------------
SECRET_KEY=
FLASK_ENV=development
FLASK_DEBUG=1

# ----------------------------------------------------------------------------
# Redis (for background jobs)
# Local: redis://localhost:6379
# Railway: auto-set by Railway Redis plugin
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
PORT=5001
